;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Frozen Embers"
run/main_scene="uid://buddqeg181ay5"
config/features=PackedStringArray("4.5", "Forward Plus")
boot_splash/bg_color=Color(0.14117648, 0.14117648, 0.28235295, 1)
boot_splash/image="uid://dd6ehn2b4itp6"
config/icon="uid://dd6ehn2b4itp6"

[autoload]

GlobalPlayerStats="*res://Scripts/_Global_/PlayerStats.gd"
GlobalLevelStats="*res://Scripts/_Global_/LevelStats.gd"
GlobalOptionSettings="*res://Scripts/_Global_/OptionSettings.gd"
MusicController="*res://Scenes/Audio/music_controller.tscn"
SpeedrunDisplay="*res://Scenes/UI/speedrun_display.tscn"

[global_group]

player_pov="Player's Camera"
player="Attached exclusively to player characters and extentions of them."
water="Used so that areas can recognise water."
exit="Used to identiy the end of a level."
player_attack="Used to mark areas that represent the player's attacks."
player_light=""
monster_attack="Used to mark areas that represent monster attacks."
minor_noise="Used to alert monsters and give them a target to chase. Low Priority."
major_noise="Used to alert mosters and give them a target to chase. High Priority."
place_of_interest="Used for monster navigation. Tells monsters when they've reached thier targeted objective if they are not currently hunting for the player."
monster="Attatched exclusively to monsters and extentions of them."

