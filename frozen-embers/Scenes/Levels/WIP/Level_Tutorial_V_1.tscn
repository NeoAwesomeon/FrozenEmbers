[node name="Messages" type="Node" parent="Gameplay"]

[node name="MessageBox" parent="Gameplay/Messages" instance=ExtResource("8_fmqyv")]
transform = Transform3D(20, 0, 0, 0, 10, 0, 0, 0, 10, 0, 5, -20)
message = "Heat (Red Bar) is what keeps you alive.
Light (Yellow Bar) is what maintains your heat and gives you power.
The noise you make is tracked by the Pink Bar.

Hold Reignite (Default: Q) to restore your light.
It will alert monsters to your location, so use it while you're safe."
duration = 20.0
one_shot = true

[node name="MessageBox3" parent="Gameplay/Messages" instance=ExtResource("8_fmqyv")]
transform = Transform3D(20, 0, 0, 0, 10, 0, 0, 0, 10, 0, 5, -37)
message = "Holding Dash (Default: Shift) will make you faster over time.
This will drain your light.

Your abilities become more potent the faster you are.

Your speed will slowly decay when the button is released."
duration = 15.0
one_shot = true

[node name="MessageBox5" parent="Gameplay/Messages" instance=ExtResource("8_fmqyv")]
transform = Transform3D(20, 0, 0, 0, 10, 0, 0, 0, 10, 0, 5, -89.99999)
message = "Press Crouch (Default: CTRL) in midair to perform an Air Dive, at the cost of some light.
This will also create a pillar of flame that walls off monsters and burns hazards.

You can jump during the start-up to cancel your dive and gain another mid-air jump.

You do not take fall damage."
duration = 20.0
one_shot = true

[node name="MessageBox6" parent="Gameplay/Messages" instance=ExtResource("8_fmqyv")]
transform = Transform3D(20, 0, 0, 0, 10, 0, 0, 0, 10, 0, -25, -149)
message = "Jumping while crouching performs a high jump, at the cost of some light."
duration = 10.0
one_shot = true

[node name="MessageBox2" parent="Gameplay/Messages" instance=ExtResource("8_fmqyv")]
transform = Transform3D(20, 0, 0, 0, 10, 0, 0, 0, 10, 0, -16, -186)
message = "You can jump off of walls 3 times before landing.
Grabing a ledge will also reset your wall jumps."
duration = 10.0
one_shot = true

[node name="MessageBox4" parent="Gameplay/Messages" instance=ExtResource("8_fmqyv")]
transform = Transform3D(20, 0, 0, 0, 10, 0, 0, 0, 5, 0, -4, -203)
message = "Wisps will give you Light upon collecting them.
"
one_shot = true

[node name="MessageBox7" parent="Gameplay/Messages" instance=ExtResource("8_fmqyv")]
transform = Transform3D(20, 0, 0, 0, 10, 0, 0, 0, 10, 0, -4, -240)
message = "Crouch while moving to slide. Jump while sliding to perform a long jump. Long jumps will use light.

Long jumps can be extended by jumping in midair again.

The greater your speed, the longer the jump will be."
duration = 20.0
one_shot = true

[node name="MessageBox8" parent="Gameplay/Messages" instance=ExtResource("8_fmqyv")]
transform = Transform3D(20, 0, 0, 0, 10, 0, 0, 0, 10, 0, -3, -291)
message = "Beacons are your main objective.

Once activated, you must pass through every ring to complete it.
Use all of your abilities to complete this beacon.

Completed Beacons will restore Light & Heat.

When all beacons are complete, the exit will open."
duration = 20.0
one_shot = true

